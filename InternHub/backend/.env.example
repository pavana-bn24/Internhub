# InternHub Backend — Environment Configuration
# Copy this file to .env and fill in your production values.

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-64-char-hex-string

# --- Admin Account (created on first startup) ---
ADMIN_USERNAME=internhub_admin
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-this-to-a-strong-password

# --- Database ---
# SQLite (development):
# DATABASE_URL=sqlite:///./internhub.db
#
# PostgreSQL (production):
DATABASE_URL=postgresql://user:password@localhost:5432/internhub
#
# For a separate test database (used by pytest when TEST_DATABASE_URL is set):
# TEST_DATABASE_URL=sqlite:///./test_internhub.db

# --- CORS ---
# Comma-separated list of allowed origins (no trailing slashes)
CORS_ORIGINS=https://app.yourdomain.com,https://admin.yourdomain.com
